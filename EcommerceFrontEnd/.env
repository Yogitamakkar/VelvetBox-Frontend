# Backend API base URL — leave empty when using the Vite proxy (development)
# For production, set this to the actual backend URL, e.g. https://api.velvetbox.com
VITE_API_BASE_URL=

# Cloudinary (fill in your own values)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
